		"AzureKeyVault_sqlserver_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://KeyValut-TrialndLearn.vault.azure.net/"
		},
		"LS_ADLS_OUTPUT_PARQUET_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlstrialandlearn.dfs.core.windows.net/"
		},
		"LS_INPUT_RESTAPI_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://retoolapi.dev/5yDVOt/data"
		},
		"LS_MULTI_OUTPUT_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlstrialandlearn.dfs.core.windows.net/"
		},
		"LS_OUTPUT_BINARY_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlstrialandlearn.dfs.core.windows.net/"
